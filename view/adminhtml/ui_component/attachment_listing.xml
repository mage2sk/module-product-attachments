<?xml version="1.0"?>
<!--
/**
 * Attachment Listing UI Component
 *
 * @category  Panth
 * @package   Panth_ProductAttachments
 * @author    Panth
 * @copyright Copyright (c) 2025 Panth
 */
-->
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">attachment_listing.attachment_listing_data_source</item>
            <item name="component" xsi:type="string">Panth_ProductAttachments/js/grid/listing</item>
        </item>
    </argument>
    <settings>
        <buttons>
            <button name="add">
                <url path="*/*/new"/>
                <class>primary</class>
                <label translate="true">Add New Attachment</label>
            </button>
        </buttons>
        <spinner>attachment_columns</spinner>
        <deps>
            <dep>attachment_listing.attachment_listing_data_source</dep>
        </deps>
    </settings>
    <dataSource name="attachment_listing_data_source" component="Magento_Ui/js/grid/provider">
        <settings>
            <storageConfig>
                <param name="indexField" xsi:type="string">attachment_id</param>
            </storageConfig>
            <updateUrl path="mui/index/render"/>
        </settings>
        <aclResource>Panth_ProductAttachments::attachment</aclResource>
        <dataProvider class="Magento\Framework\View\Element\UiComponent\DataProvider\DataProvider" name="attachment_listing_data_source">
            <settings>
                <requestFieldName>id</requestFieldName>
                <primaryFieldName>attachment_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>
    <listingToolbar name="listing_top">
        <settings>
            <sticky>true</sticky>
        </settings>
        <bookmark name="bookmarks"/>
        <columnsControls name="columns_controls"/>
        <filterSearch name="fulltext"/>
        <filters name="listing_filters">
            <settings>
                <templates>
                    <filters>
                        <select>
                            <param name="template" xsi:type="string">ui/grid/filters/elements/ui-select</param>
                            <param name="component" xsi:type="string">Magento_Ui/js/form/element/ui-select</param>
                        </select>
                    </filters>
                </templates>
            </settings>
        </filters>
        <massaction name="listing_massaction">
            <action name="delete">
                <settings>
                    <confirm>
                        <message translate="true">Are you sure you want to delete selected items?</message>
                        <title translate="true">Delete items</title>
                    </confirm>
                    <url path="productattachments/attachment/massDelete"/>
                    <type>delete</type>
                    <label translate="true">Delete</label>
                </settings>
            </action>
            <action name="status">
                <settings>
                    <type>status</type>
                    <label translate="true">Change Status</label>
                    <actions>
                        <action name="0">
                            <type>enable</type>
                            <label translate="true">Enable</label>
                            <url path="productattachments/attachment/massStatus">
                                <param name="status">1</param>
                            </url>
                        </action>
                        <action name="1">
                            <type>disable</type>
                            <label translate="true">Disable</label>
                            <url path="productattachments/attachment/massStatus">
                                <param name="status">0</param>
                            </url>
                        </action>
                    </actions>
                </settings>
            </action>
        </massaction>
        <exportButton name="export_button">
            <settings>
                <options>
                    <option name="cvs" xsi:type="array">
                        <item name="value" xsi:type="string">csv</item>
                        <item name="label" xsi:type="string" translate="true">CSV</item>
                        <item name="url" xsi:type="string">mui/export/gridToCsv</item>
                    </option>
                    <option name="xml" xsi:type="array">
                        <item name="value" xsi:type="string">xml</item>
                        <item name="label" xsi:type="string" translate="true">Excel XML</item>
                        <item name="url" xsi:type="string">mui/export/gridToXml</item>
                    </option>
                </options>
            </settings>
        </exportButton>
        <paging name="listing_paging"/>
    </listingToolbar>
    <columns name="attachment_columns">
        <settings>
            <editorConfig>
                <param name="clientConfig" xsi:type="array">
                    <item name="saveUrl" xsi:type="url" path="productattachments/attachment/inlineEdit"/>
                    <item name="validateBeforeSave" xsi:type="boolean">false</item>
                </param>
                <param name="indexField" xsi:type="string">attachment_id</param>
                <param name="enabled" xsi:type="boolean">true</param>
                <param name="selectProvider" xsi:type="string">attachment_listing.attachment_listing.attachment_columns.ids</param>
            </editorConfig>
            <childDefaults>
                <param name="fieldAction" xsi:type="array">
                    <item name="provider" xsi:type="string">attachment_listing.attachment_listing.attachment_columns_editor</item>
                    <item name="target" xsi:type="string">startEdit</item>
                    <item name="params" xsi:type="array">
                        <item name="0" xsi:type="string">${ $.$data.rowIndex }</item>
                        <item name="1" xsi:type="boolean">true</item>
                    </item>
                </param>
            </childDefaults>
        </settings>
        <selectionsColumn name="ids">
            <settings>
                <indexField>attachment_id</indexField>
            </settings>
        </selectionsColumn>
        <column name="attachment_id">
            <settings>
                <filter>textRange</filter>
                <label translate="true">ID</label>
                <sorting>asc</sorting>
            </settings>
        </column>
        <column name="title">
            <settings>
                <filter>text</filter>
                <editor>
                    <validation>
                        <rule name="required-entry" xsi:type="boolean">true</rule>
                    </validation>
                    <editorType>text</editorType>
                </editor>
                <label translate="true">Title</label>
            </settings>
        </column>
        <column name="files_info" class="Panth\ProductAttachments\Ui\Component\Listing\Column\FilesInfo">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="fieldAction" xsi:type="boolean">false</item>
                </item>
            </argument>
            <settings>
                <label translate="true">Files</label>
                <sortable>false</sortable>
                <bodyTmpl>ui/grid/cells/html</bodyTmpl>
            </settings>
        </column>
        <column name="products_info" class="Panth\ProductAttachments\Ui\Component\Listing\Column\ProductsInfo">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="fieldAction" xsi:type="boolean">false</item>
                </item>
            </argument>
            <settings>
                <label translate="true">Products</label>
                <sortable>false</sortable>
                <bodyTmpl>ui/grid/cells/html</bodyTmpl>
            </settings>
        </column>
        <column name="categories_info" class="Panth\ProductAttachments\Ui\Component\Listing\Column\CategoriesInfo">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="fieldAction" xsi:type="boolean">false</item>
                </item>
            </argument>
            <settings>
                <label translate="true">Categories</label>
                <sortable>false</sortable>
                <bodyTmpl>ui/grid/cells/html</bodyTmpl>
            </settings>
        </column>
        <column name="pages_info" class="Panth\ProductAttachments\Ui\Component\Listing\Column\PagesInfo">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="fieldAction" xsi:type="boolean">false</item>
                </item>
            </argument>
            <settings>
                <label translate="true">CMS Pages</label>
                <sortable>false</sortable>
                <bodyTmpl>ui/grid/cells/html</bodyTmpl>
            </settings>
        </column>
        <column name="attachment_type_id" component="Magento_Ui/js/grid/columns/select">
            <settings>
                <options class="Panth\ProductAttachments\Model\Config\Source\AttachmentType"/>
                <filter>select</filter>
                <dataType>select</dataType>
                <label translate="true">Type</label>
            </settings>
        </column>
        <column name="store_id" class="Magento\Store\Ui\Component\Listing\Column\Store">
            <settings>
                <label translate="true">Store View</label>
                <bodyTmpl>ui/grid/cells/html</bodyTmpl>
                <sortable>false</sortable>
            </settings>
        </column>
        <column name="customer_group_ids" class="Panth\ProductAttachments\Ui\Component\Listing\Column\CustomerGroups">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="fieldAction" xsi:type="boolean">false</item>
                </item>
            </argument>
            <settings>
                <label translate="true">Customer Groups</label>
                <sortable>false</sortable>
                <bodyTmpl>ui/grid/cells/html</bodyTmpl>
                <visible>true</visible>
            </settings>
        </column>
        <column name="is_link" component="Magento_Ui/js/grid/columns/select">
            <settings>
                <options class="Magento\Config\Model\Config\Source\Yesno"/>
                <filter>select</filter>
                <dataType>select</dataType>
                <label translate="true">Is Link</label>
                <visible>true</visible>
            </settings>
        </column>
        <column name="link_url">
            <settings>
                <filter>text</filter>
                <label translate="true">Link URL</label>
                <visible>false</visible>
            </settings>
        </column>
        <column name="download_count">
            <settings>
                <filter>textRange</filter>
                <label translate="true">Total Downloads</label>
                <visible>true</visible>
            </settings>
        </column>
        <column name="is_active" component="Magento_Ui/js/grid/columns/select">
            <settings>
                <options class="Magento\Config\Model\Config\Source\Yesno"/>
                <filter>select</filter>
                <editor>
                    <editorType>select</editorType>
                </editor>
                <dataType>select</dataType>
                <label translate="true">Status</label>
            </settings>
        </column>
        <column name="expires_at" class="Magento\Ui\Component\Listing\Columns\Date" component="Magento_Ui/js/grid/columns/date">
            <settings>
                <filter>dateRange</filter>
                <dataType>date</dataType>
                <label translate="true">Expires At</label>
            </settings>
        </column>
        <column name="created_at" class="Magento\Ui\Component\Listing\Columns\Date" component="Magento_Ui/js/grid/columns/date">
            <settings>
                <filter>dateRange</filter>
                <dataType>date</dataType>
                <label translate="true">Created</label>
            </settings>
        </column>
        <column name="updated_at" class="Magento\Ui\Component\Listing\Columns\Date" component="Magento_Ui/js/grid/columns/date">
            <settings>
                <filter>dateRange</filter>
                <dataType>date</dataType>
                <label translate="true">Modified</label>
                <visible>false</visible>
            </settings>
        </column>
        <actionsColumn name="actions" class="Panth\ProductAttachments\Ui\Component\Listing\Column\AttachmentActions">
            <settings>
                <indexField>attachment_id</indexField>
                <resizeEnabled>false</resizeEnabled>
                <resizeDefaultWidth>107</resizeDefaultWidth>
            </settings>
        </actionsColumn>
    </columns>
</listing>
