<script type="text/javascript">
require([
    'jquery',
    'Magento_Ui/js/modal/alert',
    'Magento_Ui/js/modal/confirm',
    'mage/translate'
], function($, alert, confirm, $t) {
    'use strict';

    var uploadUrl = '<?= $block->escapeJs($block->getUploadUrl()) ?>';
    var downloadUrl = '<?= $block->escapeJs($block->getDownloadUrl('FILE_ID_PLACEHOLDER')) ?>';
    var previewUrl = '<?= $block->escapeJs($block->getPreviewUrl('FILE_ID_PLACEHOLDER')) ?>';
    var deleteUrl = '<?= $block->escapeJs($block->getDeleteFileUrl()) ?>';
    var setPrimaryUrl = '<?= $block->escapeJs($block->getSetPrimaryUrl()) ?>';

    // File upload handling - auto-upload on selection
    $('#attachment-files-input').on('change', function() {
        var files = this.files;
        if (files.length > 0) {
            // Display selected files
            $('#selected-files-list').empty();
            $('#selected-files-list').append(
                '<div class="fm-uploading-message">' +
                '<span style="color: #eb5202; font-weight: bold;">' +
                $t('Uploading %1 file(s)...').replace('%1', files.length) +
                '</span>' +
                '</div>'
            );

            // Upload immediately
            uploadSelectedFiles(files, this);
        }
    });


    // Download button
    $(document).on('click', '.fm-btn-download', function() {
        var fileId = $(this).data('file-id');
        var url = downloadUrl.replace('FILE_ID_PLACEHOLDER', fileId);
        window.location.href = url;
    });

    // Preview button
    $(document).on('click', '.fm-btn-preview', function() {
        var fileId = $(this).data('file-id');
        var filename = $(this).data('filename');
        var url = previewUrl.replace('FILE_ID_PLACEHOLDER', fileId);
        
        $('#file-preview-container').html('<div style="text-align:center;padding:20px;">Loading...</div>');
        $('#file-preview-modal').fadeIn();
        
        var ext = filename.split('.').pop().toLowerCase();
        var safeFilename = $('<span>').text(filename).html();
        var safeUrl = $('<span>').text(url).html();
        if (['jpg', 'jpeg', 'png', 'gif', 'webp', 'svg'].indexOf(ext) !== -1) {
            $('#file-preview-container').html('<img src="' + safeUrl + '" alt="' + safeFilename + '" />');
        } else if (ext === 'pdf') {
            $('#file-preview-container').html('<embed src="' + safeUrl + '" type="application/pdf" width="100%" height="600px" />');
        } else {
            $('#file-preview-container').html('<iframe src="' + safeUrl + '" width="100%" height="600px" style="border:none;"></iframe>');
        }
    });

    // Close preview
    $(document).on('click', '.fm-preview-close', function() {
        $('#file-preview-modal').fadeOut();
    });

    // Delete button
    $(document).on('click', '.fm-btn-delete', function(e) {
        e.preventDefault();
        e.stopPropagation();
        e.stopImmediatePropagation();

        var fileId = $(this).data('file-id');
        var card = $(this).closest('.fm-file-card');

        confirm({
            title: $t('Delete File'),
            content: $t('Are you sure you want to delete this file? This action cannot be undone.'),
            actions: {
                confirm: function() {
                    $('body').trigger('processStart');

                    $.ajax({
                        url: deleteUrl,
                        type: 'POST',
                        data: {
                            file_id: fileId,
                            form_key: window.FORM_KEY
                        },
                        dataType: 'json',
                        success: function(response) {
                            $('body').trigger('processStop');
                            if (response.success) {
                                card.fadeOut(300, function() {
                                    $(this).remove();
                                    if ($('.fm-file-card').length === 0) {
                                        $('.fm-files-grid').html('<div class="fm-no-files"><p>' + $t('No files uploaded yet.') + '</p></div>');
                                    }
                                });
                            } else {
                                alert({
                                    title: $t('Error'),
                                    content: response.message || $t('Error deleting file')
                                });
                            }
                        },
                        error: function() {
                            $('body').trigger('processStop');
                            alert({
                                title: $t('Error'),
                                content: $t('Error deleting file. Please try again.')
                            });
                        }
                    });
                }
            }
        });
    });

    // Set Primary button
    $(document).on('click', '.fm-btn-primary', function(e) {
        e.preventDefault();
        e.stopPropagation();
        e.stopImmediatePropagation();

        var fileId = $(this).data('file-id');

        confirm({
            title: $t('Set Primary File'),
            content: $t('Are you sure you want to set this file as the primary file?'),
            actions: {
                confirm: function() {
                    $('body').trigger('processStart');

                    console.log('Setting file as primary:', fileId);

                    $.ajax({
                        url: setPrimaryUrl,
                        type: 'POST',
                        data: {
                            file_id: fileId,
                            form_key: window.FORM_KEY
                        },
                        dataType: 'json',
                        success: function(response) {
                            $('body').trigger('processStop');
                            console.log('Set primary response:', response);

                            if (response.success) {
                                console.log('Primary file set successfully, reloading file list...');

                                // Reload the entire file list to show updated primary badge
                                loadFileList();
                            } else {
                                console.error('Failed to set primary:', response.message);
                                alert({
                                    title: $t('Error'),
                                    content: response.message || $t('Error setting primary file')
                                });
                            }
                        },
                        error: function(xhr, status, error) {
                            $('body').trigger('processStop');
                            console.error('Set primary error:', error, status, xhr.responseText);
                            alert({
                                title: $t('Error'),
                                content: $t('Error setting primary file. Please try again.')
                            });
                        }
                    });
                }
            }
        });

        return false;
    });

    // Close modal button
    $(document).on('click', '.fm-close-btn', function(e) {
        e.preventDefault();
        e.stopPropagation();

        console.log('Close button clicked, closing modal...');

        // Find the modal wrapper that has the stored modal instance
        var modalWrapper = $('.attachment-file-manager-modal-wrapper');

        if (modalWrapper.length) {
            var modalInstance = modalWrapper.data('modalInstance');

            if (modalInstance && typeof modalInstance.closeModal === 'function') {
                // Use the stored modal instance
                // Grid reload will happen automatically via modalclosed event in file-manager-modal.js
                modalInstance.closeModal();
            } else {
                // Fallback: try to close via jQuery UI modal
                var modalPopup = $('.modal-popup._show').first();
                if (modalPopup.length) {
                    try {
                        modalPopup.modal('closeModal');
                    } catch (e) {
                        // If that fails, just hide it
                        modalPopup.hide();
                        $('.modals-overlay').hide();
                    }
                }
            }
        }

        return false;
    });

    // Upload selected files function
    function uploadSelectedFiles(files, inputElement) {
        if (!files || files.length === 0) {
            console.log('No files to upload');
            return;
        }

        var attachmentId = $('.file-manager-modal-content').data('attachment-id') || 0;
        console.log('Uploading files for attachment ID:', attachmentId);
        console.log('Number of files:', files.length);

        // Create FormData for file upload
        var formData = new FormData();
        formData.append('form_key', window.FORM_KEY);
        formData.append('attachment_id', attachmentId);

        // Append all selected files
        for (var i = 0; i < files.length; i++) {
            formData.append('files[]', files[i]);
            console.log('Added file:', files[i].name);
        }

        // Perform AJAX upload
        $.ajax({
            url: uploadUrl,
            type: 'POST',
            data: formData,
            processData: false,
            contentType: false,
            cache: false,
            success: function(response) {
                console.log('Upload response:', response);

                if (response.success) {
                    // Show success message
                    $('#selected-files-list').html(
                        '<div class="fm-success-message" style="color: #3c763d; font-weight: bold; padding: 10px; background: #dff0d8; border-radius: 4px;">' +
                        response.message +
                        '</div>'
                    );

                    // Clear the file input
                    $(inputElement).val('');

                    console.log('Upload successful, reloading file list in 500ms...');

                    // Reload the file list via AJAX
                    setTimeout(function() {
                        console.log('Now calling loadFileList()');
                        loadFileList();
                    }, 500);
                } else {
                    console.error('Upload failed:', response.message);
                    // Show error message
                    $('#selected-files-list').html(
                        '<div class="fm-error-message" style="color: #a94442; font-weight: bold; padding: 10px; background: #f2dede; border-radius: 4px;">' +
                        (response.message || $t('Upload failed. Please try again.')) +
                        '</div>'
                    );
                    $(inputElement).val('');
                }
            },
            error: function(xhr, status, error) {
                console.error('Upload error:', error, status, xhr.responseText);
                $('#selected-files-list').html(
                    '<div class="fm-error-message" style="color: #a94442; font-weight: bold; padding: 10px; background: #f2dede; border-radius: 4px;">' +
                    $t('Upload failed: ') + error +
                    '</div>'
                );
                $(inputElement).val('');
            }
        });
    }

    // Load file list via AJAX
    function loadFileList() {
        var attachmentId = $('.file-manager-modal-content').data('attachment-id') || 0;

        console.log('Loading file list for attachment ID:', attachmentId);

        $.ajax({
            url: '<?= $block->escapeUrl($block->getUrl('productattachments/attachment/fileList')) ?>',
            type: 'GET',
            data: {
                attachment_id: attachmentId
            },
            success: function(response) {
                console.log('File list response:', response);

                if (response.success && response.html) {
                    // Find the files section and update it
                    var $filesSection = $('.fm-files-section');
                    console.log('Files section found:', $filesSection.length);

                    if ($filesSection.length) {
                        // Remove existing grid or no-files div
                        $filesSection.find('.fm-files-grid, .fm-no-files').remove();

                        // Append new HTML after the h3
                        $filesSection.find('h3').after(response.html);

                        console.log('File list updated successfully');

                        // Clear success message after reload
                        setTimeout(function() {
                            $('#selected-files-list').empty();
                        }, 2000);
                    } else {
                        console.error('Files section not found!');
                    }
                } else {
                    console.error('Invalid response:', response);
                }
            },
            error: function(xhr, status, error) {
                console.error('Failed to reload file list:', error);
                console.error('Status:', status);
                console.error('Response:', xhr.responseText);
            }
        });
    }

    function formatBytes(bytes) {
        if (bytes === 0) return '0 Bytes';
        var k = 1024;
        var sizes = ['Bytes', 'KB', 'MB', 'GB'];
        var i = Math.floor(Math.log(bytes) / Math.log(k));
        return Math.round(bytes / Math.pow(k, i) * 100) / 100 + ' ' + sizes[i];
    }
});
</script>
