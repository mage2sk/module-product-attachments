<?xml version="1.0"?>
<!--
/**
 * Hyva Layout
 * - Load attachments.css (Luma uses compiled _module.less)
 * - Move attachments from product tabs back to product.info.main (Hyva design)
 */
-->
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <css src="Panth_ProductAttachments::css/attachments.css"/>
    </head>
    <body>
        <!-- Move attachments from tabs to product.info.main for Hyva -->
        <move element="product.attachments" destination="product.info.main" after="-"/>
    </body>
</page>
