<?php
/**
 * Advanced Attachment Renderer Template - Hyva Theme
 * Uses same Bootstrap design as Luma, but with Alpine.js instead of RequireJS
 *
 * @category  Panth
 * @package   Panth_ProductAttachments
 * @author    Panth
 * @copyright Copyright (c) 2025 Panth
 */

/** @var \Panth\ProductAttachments\Block\Attachment\Renderer $block */

// Check if module is enabled
if (!$block->isModuleEnabled()) {
    return '';
}

// Get attachments collection
$attachments = $block->getAttachments();
if ($attachments->getSize() === 0) {
    return '';
}

// Get view mode (table or list)
$viewMode = $block->getViewMode();
$attachmentsArray = $attachments->getItems();

// Calculate total items (links + files)
$totalItems = 0;
foreach ($attachmentsArray as $attachment) {
    if ($block->hasLink($attachment)) {
        $totalItems++; // Count the link
    }
    if ($block->hasFiles($attachment)) {
        $totalItems += $attachment->getFiles()->getSize(); // Count all files
    }
}
?>

<?php
// Get context prefix for unique IDs
$contextPrefixMain = $block->getContextPrefix();
?>
<div class="panth-product-attachment-module panth-attachment-wrapper"
     id="panth-attachments-<?= $block->escapeHtmlAttr($contextPrefixMain) ?><?= $block->escapeHtmlAttr($viewMode) ?>"
     data-view-mode="<?= $block->escapeHtmlAttr($viewMode) ?>"
     x-data="attachmentPreview()">

    <!-- Header Section -->
    <div class="pa-header">
        <h2 class="pa-title">
            <i class="fas fa-paperclip"></i>
            <?= $block->escapeHtml(__('Attachments & Downloads')) ?>
            <span class="pa-count">(<?= (int)$totalItems ?>)</span>
        </h2>
    </div>

    <!-- Attachments Container -->
    <div class="pa-content" id="pa-attachments-content">
        <?php
        // Get context prefix for unique IDs
        $contextPrefix = $block->getContextPrefix();

        // Load the appropriate view mode template
        $viewModeTemplate = 'Panth_ProductAttachments::attachment/view-modes/' . $viewMode . '_hyva.phtml';
        echo $block->getLayout()
            ->createBlock(\Panth\ProductAttachments\Block\Attachment\Renderer::class)
            ->setTemplate($viewModeTemplate)
            ->setData('attachments', $attachmentsArray)
            ->setData('parent_block', $block)
            ->setData('context_prefix', $contextPrefix)
            ->toHtml();
        ?>
    </div>

    <!-- No Results Message -->
    <div class="pa-no-results" style="display:none;">
        <i class="fas fa-search"></i>
        <p><?= $block->escapeHtml(__('No attachments found matching your criteria.')) ?></p>
        <button class="pa-reset-search"><?= $block->escapeHtml(__('Clear Search & Filters')) ?></button>
    </div>

    <!-- Loading Overlay -->
    <div class="pa-loading-overlay" style="display:none;">
        <div class="pa-spinner"></div>
        <p><?= $block->escapeHtml(__('Loading...')) ?></p>
    </div>

    <!-- Preview Modal Container (same as Luma modal structure) -->
    <div x-show="showModal"
         x-cloak
         @keydown.escape.window="showModal = false"
         class="modals-wrapper">
        <div class="modals-overlay" @click="showModal = false"></div>
        <aside class="modal-popup" role="dialog">
            <div class="modal-inner-wrap">
                <button class="action-close" @click="showModal = false" type="button" aria-label="Close">
                    <span><?= $block->escapeHtml(__('Close')) ?></span>
                </button>
                <div class="modal-content" x-html="modalContent"></div>
            </div>
        </aside>
    </div>
</div>

<!-- Guest Login Modal (if guest downloads not allowed) -->
<?php if (!$block->allowGuestDownloads() && !$block->isCustomerLoggedIn()): ?>
<div id="pa-guest-login-modal" style="display:none;">
    <div class="pa-guest-modal-content">
        <button class="pa-modal-close"><i class="fas fa-times"></i></button>
        <i class="fas fa-lock pa-lock-icon"></i>
        <h3><?= $block->escapeHtml(__('Login Required')) ?></h3>
        <p><?= $block->escapeHtml(__('Please login or create an account to download this attachment.')) ?></p>
        <div class="pa-modal-actions">
            <a href="<?= $block->escapeUrl($block->getLoginUrl()) ?>" class="pa-btn pa-btn-primary">
                <i class="fas fa-sign-in-alt"></i>
                <?= $block->escapeHtml(__('Login')) ?>
            </a>
            <a href="<?= $block->escapeUrl($block->getCreateAccountUrl()) ?>" class="pa-btn pa-btn-secondary">
                <i class="fas fa-user-plus"></i>
                <?= $block->escapeHtml(__('Create Account')) ?>
            </a>
        </div>
    </div>
</div>
<?php endif; ?>

<script>
function attachmentPreview() {
    return {
        showModal: false,
        modalContent: '',

        _escHtml(str) {
            const map = {'&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#039;'};
            return String(str).replace(/[&<>"']/g, function (m) { return map[m]; });
        },

        openPreview(previewUrl, filename, filetype, attachmentId, fileId, isDownloadable, fileInfo) {
            fileInfo = fileInfo || {};
            const previewableTypes = ['PDF', 'JPG', 'JPEG', 'PNG', 'GIF', 'SVG', 'WEBP', 'BMP'];
            let content = '';

            // File information header (same as Luma)
            const esc = this._escHtml.bind(this);
            const fileInfoHtml = '<div style="background: var(--pa-bg-hover, #f5f5f5); padding: 15px; margin-bottom: 15px; border-radius: 4px;">' +
                '<div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 10px;">' +
                '<div>' +
                '<h4 style="margin: 0 0 5px 0; color: var(--pa-text, #171717);">' + esc(fileInfo.title || filename) + '</h4>' +
                '<p style="margin: 0; color: var(--pa-text-secondary, #525252); font-size: 14px;">' +
                '<i class="bi bi-file-earmark"></i> ' + esc(filename) +
                '</p>' +
                '</div>' +
                '<div style="text-align: right;">' +
                '<span class="badge bg-secondary" style="display: inline-block; margin-bottom: 5px;">' + esc(fileInfo.type || filetype) + '</span><br>' +
                '<small style="color: var(--pa-text-secondary, #525252);"><i class="bi bi-hdd"></i> ' + esc(fileInfo.size || 'Unknown size') + '</small>' +
                '</div>' +
                '</div>' +
                '</div>';

            content += fileInfoHtml;

            // Build preview content based on file type (same as Luma)
            if (previewableTypes.indexOf(filetype.toUpperCase()) !== -1) {
                if (filetype.toUpperCase() === 'PDF') {
                    content += '<div style="text-align: center; background: var(--pa-bg-hover, #f5f5f5); padding: 10px; border-radius: 4px;">' +
                        '<iframe src="' + esc(previewUrl) + '" width="100%" height="600px" style="border: 1px solid var(--pa-border, #e5e5e5); border-radius: 4px;"></iframe>' +
                        '</div>';
                } else {
                    // Images
                    content += '<div style="text-align: center; background: var(--pa-bg-hover, #f5f5f5); padding: 20px; border-radius: 4px;">' +
                        '<img src="' + esc(previewUrl) + '" alt="Preview" style="max-width: 100%; height: auto; border-radius: 4px; box-shadow: 0 2px 8px rgba(0,0,0,0.1);" />' +
                        '</div>';
                }
            } else {
                // Non-previewable files (same as Luma)
                let icon = 'bi-file-earmark';
                const fileTypeUpper = filetype.toUpperCase();

                // Set specific icons for different file types
                if (['DOC', 'DOCX'].indexOf(fileTypeUpper) !== -1) icon = 'bi-file-earmark-word';
                else if (['XLS', 'XLSX'].indexOf(fileTypeUpper) !== -1) icon = 'bi-file-earmark-excel';
                else if (['PPT', 'PPTX'].indexOf(fileTypeUpper) !== -1) icon = 'bi-file-earmark-ppt';
                else if (['ZIP', 'RAR', '7Z'].indexOf(fileTypeUpper) !== -1) icon = 'bi-file-earmark-zip';
                else if (['MP4', 'AVI', 'MOV'].indexOf(fileTypeUpper) !== -1) icon = 'bi-file-earmark-play';
                else if (['MP3', 'WAV'].indexOf(fileTypeUpper) !== -1) icon = 'bi-file-earmark-music';
                else if (['TXT', 'CSV'].indexOf(fileTypeUpper) !== -1) icon = 'bi-file-earmark-text';

                content += '<div style="text-align: center; padding: 60px 40px; background: var(--pa-bg-hover, #f5f5f5); border-radius: 4px;">' +
                    '<i class="bi ' + icon + '" style="font-size: 80px; color: var(--pa-icon-muted, #bdc3c7); margin-bottom: 20px;"></i>' +
                    '<h4 style="color: var(--pa-text-secondary, #525252); margin-bottom: 10px;">Preview Not Available</h4>' +
                    '<p style="color: var(--pa-text-muted, #a3a3a3); margin-bottom: 20px;">This file type (' + esc(filetype.toUpperCase()) + ') cannot be previewed in the browser.</p>' +
                    '<p style="color: var(--pa-text-muted, #a3a3a3);">Please download the file to view its contents.</p>' +
                    '</div>';
            }

            // Add action buttons (same as Luma)
            let actionsHtml = '<div style="text-align: center; padding: 20px; border-top: 1px solid var(--pa-border, #e5e5e5); margin-top: 20px;">';

            if (isDownloadable) {
                let downloadUrl = '<?= $block->escapeUrl($block->getUrl('productattachments/download/file')) ?>';
                downloadUrl += '?id=' + attachmentId;
                if (fileId) {
                    downloadUrl += '&file_id=' + fileId;
                }
                actionsHtml += '<button class="action primary" onclick="window.location.href=\'' + downloadUrl + '\'" style="margin-right: 10px;">' +
                    '<span><i class="bi bi-download"></i> Download File</span>' +
                    '</button>';
            } else {
                actionsHtml += '<button class="action secondary" disabled title="Login required to download">' +
                    '<span><i class="bi bi-lock"></i> Login Required</span>' +
                    '</button>';
            }

            actionsHtml += '</div>';
            content += actionsHtml;

            // Set content and show modal
            this.modalContent = content;
            this.showModal = true;
        }
    }
}
</script>
