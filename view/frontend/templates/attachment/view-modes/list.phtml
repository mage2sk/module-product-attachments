<?php
/**
 * List View - Bootstrap Layout
 */
/** @var \Panth\ProductAttachments\Block\Attachment\Renderer $parentBlock */
$parentBlock = $this->getData('parent_block');
$attachments = $this->getData('attachments') ?: [];

if (empty($attachments)) {
    return '';
}

// Group: Links first, then files by type
$links = [];
$filesByType = [];

foreach ($attachments as $attachment) {
    if ($parentBlock->hasLink($attachment)) {
        $links[] = ['attachment' => $attachment];
    }
    if ($parentBlock->hasFiles($attachment)) {
        foreach ($attachment->getFiles() as $file) {
            $ext = strtoupper(pathinfo($file->getOriginalFilename(), PATHINFO_EXTENSION));
            $filesByType[$ext][] = ['attachment' => $attachment, 'file' => $file];
        }
    }
}

// Map file types to Bootstrap Icons
$iconMap = [
    // Documents
    'PDF' => 'bi-file-earmark-pdf',
    'DOC' => 'bi-file-earmark-word',
    'DOCX' => 'bi-file-earmark-word',
    'XLS' => 'bi-file-earmark-excel',
    'XLSX' => 'bi-file-earmark-excel',
    'PPT' => 'bi-file-earmark-ppt',
    'PPTX' => 'bi-file-earmark-ppt',
    'TXT' => 'bi-file-earmark-text',
    'RTF' => 'bi-file-earmark-richtext',
    'CSV' => 'bi-file-earmark-spreadsheet',

    // Archives
    'ZIP' => 'bi-file-earmark-zip',
    'RAR' => 'bi-file-earmark-zip',
    '7Z' => 'bi-file-earmark-zip',
    'TAR' => 'bi-file-earmark-zip',
    'GZ' => 'bi-file-earmark-zip',

    // Images
    'JPG' => 'bi-file-earmark-image',
    'JPEG' => 'bi-file-earmark-image',
    'PNG' => 'bi-file-earmark-image',
    'GIF' => 'bi-file-earmark-image',
    'BMP' => 'bi-file-earmark-image',
    'SVG' => 'bi-file-earmark-image',
    'WEBP' => 'bi-file-earmark-image',
    'ICO' => 'bi-file-earmark-image',

    // Videos
    'MP4' => 'bi-file-earmark-play',
    'AVI' => 'bi-file-earmark-play',
    'MOV' => 'bi-file-earmark-play',
    'WMV' => 'bi-file-earmark-play',
    'MKV' => 'bi-file-earmark-play',
    'FLV' => 'bi-file-earmark-play',
    'WEBM' => 'bi-file-earmark-play',
    'M4V' => 'bi-file-earmark-play',

    // Audio
    'MP3' => 'bi-file-earmark-music',
    'WAV' => 'bi-file-earmark-music',
    'AAC' => 'bi-file-earmark-music',
    'OGG' => 'bi-file-earmark-music',
    'M4A' => 'bi-file-earmark-music',
    'FLAC' => 'bi-file-earmark-music',
    'WMA' => 'bi-file-earmark-music',

    // Code
    'HTML' => 'bi-file-earmark-code',
    'CSS' => 'bi-file-earmark-code',
    'JS' => 'bi-file-earmark-code',
    'PHP' => 'bi-file-earmark-code',
    'PY' => 'bi-file-earmark-code',
    'JAVA' => 'bi-file-earmark-code',
    'CPP' => 'bi-file-earmark-code',
    'C' => 'bi-file-earmark-code',
    'JSON' => 'bi-file-earmark-code',
    'XML' => 'bi-file-earmark-code',

    // Binary
    'EXE' => 'bi-file-earmark-binary',
    'DLL' => 'bi-file-earmark-binary',
    'BIN' => 'bi-file-earmark-binary',
];
?>

<div class="list-group list-group-flush">
    <?php if (!empty($links)): ?>
    <?php foreach ($links as $item): ?>
    <?php $attachment = $item['attachment']; ?>
    <div class="list-group-item d-flex gap-3 align-items-center"
         data-attachment-id="<?= (int)$attachment->getId() ?>"
         data-downloadable="1">
        <div class="pa-list-icon">
            <i class="bi bi-link-45deg"></i>
        </div>
        <div class="flex-grow-1">
            <strong class="d-block mb-1"><?= $block->escapeHtml($attachment->getTitle()) ?></strong>
            <div class="d-flex gap-2 align-items-center flex-wrap">
                <span class="badge bg-info pa-type-badge">LINK</span>
                <small class="pa-filename"><?= $block->escapeHtml($attachment->getLinkUrl()) ?></small>
            </div>
        </div>
        <a href="<?= $block->escapeUrl($attachment->getLinkUrl()) ?>"
           class="btn btn-primary btn-sm"
           target="<?= $block->escapeHtmlAttr($attachment->getLinkTarget() ?: '_blank') ?>"
           title="<?= $block->escapeHtmlAttr(__('Open Link')) ?>">
            <i class="bi bi-box-arrow-up-right"></i>
        </a>
    </div>
    <?php endforeach; ?>
    <?php endif; ?>

    <?php if (!empty($filesByType)): ?>
    <?php foreach ($filesByType as $type => $items): ?>
    <?php foreach ($items as $item): ?>
    <?php
        $attachment = $item['attachment'];
        $file = $item['file'];
        $isDownloadable = $parentBlock->isDownloadable($attachment);
        $fileSize = $file->getFileSize();

        // Get icon class - prioritize attachment type icon over file extension
        $attachmentIconClass = $parentBlock->getFileIconClass($attachment);
        // Convert FontAwesome to Bootstrap Icons if needed
        if (strpos($attachmentIconClass, 'fas ') === 0 || strpos($attachmentIconClass, 'fa ') === 0) {
            // Use file extension icon as fallback
            $iconClass = $iconMap[$type] ?? 'bi-file-earmark';
        } else {
            $iconClass = $attachmentIconClass;
        }

        // Get attachment type name if available
        $typeName = $type;
        $typeId = $attachment->getAttachmentTypeId();
        if ($typeId && method_exists($attachment, 'getType') && $attachment->getType()) {
            $typeName = $attachment->getType()->getName();
            // Prioritize attachment type icon if available
            if ($attachment->getType()->getIconClass()) {
                $iconClass = $attachment->getType()->getIconClass();
            }
        }
    ?>
    <div class="list-group-item d-flex gap-3 align-items-center"
         data-attachment-id="<?= (int)$attachment->getId() ?>"
         data-file-id="<?= (int)$file->getFileId() ?>"
         data-downloadable="<?= $isDownloadable ? '1' : '0' ?>">
        <div class="pa-list-icon">
            <i class="<?= $block->escapeHtmlAttr($iconClass) ?>"></i>
        </div>
        <div class="flex-grow-1">
            <strong class="d-block mb-1"><?= $block->escapeHtml($attachment->getTitle()) ?></strong>
            <div class="d-flex gap-2 align-items-center flex-wrap">
                <span class="badge bg-secondary pa-type-badge"><?= $block->escapeHtml($typeName) ?></span>
                <small class="pa-filename"><?= $block->escapeHtml($file->getOriginalFilename()) ?></small>
                <?php if ($fileSize > 0 && $parentBlock->showFileSize()): ?>
                <small class="text-muted">• <?= $block->escapeHtml($parentBlock->formatFileSize($fileSize)) ?></small>
                <?php endif; ?>
            </div>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-info btn-sm pa-preview-btn"
                    data-attachment-id="<?= (int)$attachment->getId() ?>"
                    data-file-id="<?= (int)$file->getFileId() ?>"
                    data-filename="<?= $block->escapeHtmlAttr($file->getOriginalFilename()) ?>"
                    data-filetype="<?= $block->escapeHtmlAttr($type) ?>"
                    data-downloadable="<?= $isDownloadable ? '1' : '0' ?>"
                    title="<?= $block->escapeHtmlAttr(__('Preview')) ?>">
                <i class="bi bi-eye"></i>
            </button>
            <?php if ($isDownloadable): ?>
            <button class="btn btn-primary btn-sm pa-download-btn"
                    data-attachment-id="<?= (int)$attachment->getId() ?>"
                    data-file-id="<?= (int)$file->getFileId() ?>"
                    title="<?= $block->escapeHtmlAttr(__('Download')) ?>">
                <i class="bi bi-download"></i>
            </button>
            <?php else: ?>
            <a href="<?= $block->escapeUrl($block->getUrl('customer/account/login')) ?>"
               class="btn btn-warning btn-sm pa-login-btn"
               data-post='{"action":"<?= $block->escapeUrl($block->getUrl('customer/account/loginPost')) ?>","data":{"context":"attachments"}}'
               title="<?= $block->escapeHtmlAttr(__('Login to Download')) ?>">
                <i class="bi bi-box-arrow-in-right"></i>
            </a>
            <?php endif; ?>
        </div>
    </div>
    <?php endforeach; ?>
    <?php endforeach; ?>
    <?php endif; ?>
</div>

<!-- Modal Container for List View -->
<?php $contextPrefix = $parentBlock->getContextPrefix(); ?>
<div id="pa-preview-modal-container-<?= $block->escapeHtmlAttr($contextPrefix) ?>list" style="display:none;">
    <div id="pa-preview-modal-content-<?= $block->escapeHtmlAttr($contextPrefix) ?>list"></div>
</div>

<script>
require(['jquery', 'Magento_Ui/js/modal/modal'], function($, modal) {
    'use strict';

    var contextPrefix = '<?= $block->escapeJs($contextPrefix) ?>';
    var previewModalList = null;
    var containerId = '#panth-attachments-' + contextPrefix + '<?= $block->escapeJs($parentBlock->getViewMode()) ?>';

    // Download button click handler - scoped to this widget only
    $(document).on('click', containerId + ' .pa-download-btn', function(e) {
        e.preventDefault();

        var $btn = $(this);
        var attachmentId = $btn.data('attachment-id');
        var fileId = $btn.data('file-id');

        if (!attachmentId) {
            console.error('No attachment ID found');
            return;
        }

        // Build download URL
        var downloadUrl = '<?= $block->escapeUrl($block->getUrl('productattachments/download/file')) ?>';
        downloadUrl += '?id=' + attachmentId;
        if (fileId) {
            downloadUrl += '&file_id=' + fileId;
        }

        // Trigger download
        window.location.href = downloadUrl;
    });

    // Preview button click handler - scoped to this widget only
    $(document).on('click', containerId + ' .pa-preview-btn', function(e) {
        e.preventDefault();

        var $btn = $(this);
        var $listItem = $btn.closest('.list-group-item');
        var attachmentId = $btn.data('attachment-id');
        var fileId = $btn.data('file-id');
        var filename = $btn.data('filename');
        var filetype = $btn.data('filetype');
        var isDownloadable = $btn.data('downloadable') === 1;

        if (!attachmentId) {
            console.error('No attachment ID found');
            return;
        }

        // Get additional info from list item
        var attachmentTitle = $listItem.find('strong').first().text();
        var fileSize = $listItem.find('small.text-muted').text().replace('•', '').trim() || 'N/A';
        var typeBadge = $listItem.find('.badge').text() || filetype;

        // Build preview URL
        var previewUrl = '<?= $block->escapeUrl($block->getUrl('productattachments/preview/file')) ?>';
        previewUrl += '?id=' + attachmentId;
        if (fileId) {
            previewUrl += '&file_id=' + fileId;
        }

        // Show modal with all file information
        openPreviewModal(previewUrl, filename, filetype, attachmentId, fileId, isDownloadable, {
            title: attachmentTitle,
            size: fileSize,
            type: typeBadge
        });
    });

    // Open preview modal with enhanced file information
    function _escHtml(str) {
        var map = {'&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#039;'};
        return String(str).replace(/[&<>"']/g, function (m) { return map[m]; });
    }

    function openPreviewModal(previewUrl, filename, filetype, attachmentId, fileId, isDownloadable, fileInfo) {
        fileInfo = fileInfo || {};
        var previewableTypes = ['PDF', 'JPG', 'JPEG', 'PNG', 'GIF', 'SVG', 'WEBP', 'BMP'];
        var fileTypeUpper = filetype.toUpperCase();
        var content = '';

        // File information header with responsive design
        var fileInfoHtml = '<div style="background: var(--pa-bg-hover, #f5f5f5); padding: 15px; margin-bottom: 15px; border-radius: 4px; border-left: 4px solid var(--pa-primary, #0D9488);">' +
            '<div style="display: flex; justify-content: space-between; align-items: start; flex-wrap: wrap; gap: 15px;">' +
            '<div style="flex: 1; min-width: 200px;">' +
            '<h4 style="margin: 0 0 8px 0; color: var(--pa-text, #171717); font-size: 18px; font-weight: 600;">' +
            '<i class="bi bi-file-earmark-text" style="margin-right: 8px; color: var(--pa-primary, #0D9488);"></i>' +
            _escHtml(fileInfo.title || filename) + '</h4>' +
            '<p style="margin: 0; color: var(--pa-text-secondary, #525252); font-size: 14px; line-height: 1.5;">' +
            '<i class="bi bi-paperclip" style="margin-right: 5px;"></i>' + _escHtml(filename) +
            '</p>' +
            '</div>' +
            '<div style="text-align: right; min-width: 120px;">' +
            '<span class="badge bg-secondary" style="display: inline-block; margin-bottom: 8px; font-size: 13px; padding: 6px 12px;">' +
            _escHtml(fileInfo.type || filetype) + '</span><br>' +
            '<small style="color: var(--pa-text-secondary, #525252); font-size: 13px;"><i class="bi bi-hdd" style="margin-right: 5px;"></i>' +
            _escHtml(fileInfo.size || 'Unknown size') + '</small>' +
            '</div>' +
            '</div>' +
            '</div>';

        content += fileInfoHtml;

        // Build preview content based on file type
        if (previewableTypes.indexOf(fileTypeUpper) !== -1) {
            if (fileTypeUpper === 'PDF') {
                content += '<div style="text-align: center; background: #fff; padding: 10px; border-radius: 4px;">' +
                    '<iframe src="' + _escHtml(previewUrl) + '" width="100%" height="600px" style="border: 1px solid var(--pa-border, #e5e5e5); border-radius: 4px;"></iframe>' +
                    '</div>';
            } else {
                content += '<div style="text-align: center; background: #fff; padding: 20px; border-radius: 4px;">' +
                    '<img src="' + _escHtml(previewUrl) + '" alt="Preview" style="max-width: 100%; height: auto; border-radius: 4px; box-shadow: 0 2px 8px rgba(0,0,0,0.1);" />' +
                    '</div>';
            }
        } else {
            // Type-specific icons for non-previewable files
            var icon = 'bi-file-earmark';
            var iconColor = 'var(--pa-text-secondary, #525252)';

            if (['DOC', 'DOCX'].indexOf(fileTypeUpper) !== -1) {
                icon = 'bi-file-earmark-word';
                iconColor = '#2b579a';
            } else if (['XLS', 'XLSX'].indexOf(fileTypeUpper) !== -1) {
                icon = 'bi-file-earmark-excel';
                iconColor = '#217346';
            } else if (['PPT', 'PPTX'].indexOf(fileTypeUpper) !== -1) {
                icon = 'bi-file-earmark-ppt';
                iconColor = '#d24726';
            } else if (['ZIP', 'RAR', '7Z', 'TAR', 'GZ'].indexOf(fileTypeUpper) !== -1) {
                icon = 'bi-file-earmark-zip';
                iconColor = '#f0ad4e';
            } else if (['MP4', 'AVI', 'MOV', 'WMV', 'MKV', 'FLV', 'WEBM', 'M4V'].indexOf(fileTypeUpper) !== -1) {
                icon = 'bi-file-earmark-play';
                iconColor = '#d9534f';
            } else if (['MP3', 'WAV', 'AAC', 'OGG', 'M4A', 'FLAC', 'WMA'].indexOf(fileTypeUpper) !== -1) {
                icon = 'bi-file-earmark-music';
                iconColor = '#9b59b6';
            } else if (['HTML', 'CSS', 'JS', 'PHP', 'PY', 'JAVA', 'CPP', 'C', 'JSON', 'XML'].indexOf(fileTypeUpper) !== -1) {
                icon = 'bi-file-earmark-code';
                iconColor = '#5cb85c';
            } else if (['TXT', 'CSV'].indexOf(fileTypeUpper) !== -1) {
                icon = 'bi-file-earmark-text';
                iconColor = '#5bc0de';
            }

            content += '<div style="text-align: center; padding: 60px 20px; background: var(--pa-bg-hover, #f5f5f5); border-radius: 4px; margin: 10px 0;">' +
                '<i class="bi ' + icon + '" style="font-size: 80px; color: ' + iconColor + '; margin-bottom: 20px; display: block;"></i>' +
                '<h5 style="color: var(--pa-text, #171717); margin: 0 0 10px 0; font-weight: 600;">Preview Not Available</h5>' +
                '<p style="color: var(--pa-text-secondary, #525252); margin: 0; font-size: 14px;">This file type cannot be previewed in the browser.</p>' +
                '<p style="color: var(--pa-text-secondary, #525252); margin: 5px 0 0 0; font-size: 14px;">Please download the file to view its contents.</p>' +
                '</div>';
        }

        // Add download button if downloadable with improved styling
        if (isDownloadable) {
            var downloadUrl = '<?= $block->escapeUrl($block->getUrl('productattachments/download/file')) ?>';
            downloadUrl += '?id=' + attachmentId;
            if (fileId) {
                downloadUrl += '&file_id=' + fileId;
            }
            content += '<div style="text-align: center; padding: 20px 15px; border-top: 2px solid var(--pa-border, #e5e5e5); margin-top: 15px;">' +
                '<button class="action primary" onclick="window.location.href=\'' + downloadUrl + '\'" ' +
                'style="background: var(--pa-primary, #0D9488); border-color: var(--pa-primary, #0D9488); padding: 10px 24px; font-size: 16px; font-weight: 500; border-radius: 4px; transition: all 0.3s;">' +
                '<span><i class="bi bi-download" style="margin-right: 8px;"></i>Download File</span>' +
                '</button>' +
                '</div>';
        } else {
            content += '<div style="text-align: center; padding: 20px 15px; border-top: 2px solid var(--pa-border, #e5e5e5); margin-top: 15px;">' +
                '<p style="color: var(--pa-text-secondary, #525252); margin: 0; font-size: 14px;"><i class="bi bi-lock" style="margin-right: 5px;"></i>Please log in to download this file.</p>' +
                '</div>';
        }

        // Update content first
        $('#pa-preview-modal-content-' + contextPrefix + 'list').html(content);

        // Create modal if not exists
        if (!previewModalList) {
            var modalOptions = {
                type: 'popup',
                responsive: true,
                innerScroll: true,
                title: false,
                buttons: []
            };

            previewModalList = modal(modalOptions, $('#pa-preview-modal-container-' + contextPrefix + 'list'));

            // Add close button to modal after it's created
            var $modalElement = $('#pa-preview-modal-container-' + contextPrefix + 'list');
            if ($modalElement.find('.action-close').length === 0) {
                $modalElement.find('.modal-inner-wrap').prepend(
                    '<button class="action-close pa-modal-close-btn" type="button" aria-label="Close">' +
                    '<span>Close</span>' +
                    '</button>'
                );

                // Bind close button click event
                $modalElement.on('click', '.action-close', function() {
                    previewModalList.closeModal();
                });
            }
        }

        // Open modal using the modal object
        previewModalList.openModal();
    }
});
</script>
