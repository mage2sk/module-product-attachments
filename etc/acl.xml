<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:Acl/etc/acl.xsd">
    <acl>
        <resources>
            <resource id="Magento_Backend::admin">
                <resource id="Panth_ProductAttachments::productattachments" title="Product Attachments" sortOrder="100">
                    <resource id="Panth_ProductAttachments::attachment" title="Manage Attachments" sortOrder="10">
                        <resource id="Panth_ProductAttachments::attachment_save" title="Save Attachment" sortOrder="10"/>
                        <resource id="Panth_ProductAttachments::attachment_delete" title="Delete Attachment" sortOrder="20"/>
                    </resource>
                    <resource id="Panth_ProductAttachments::type" title="Attachment Types" sortOrder="20">
                        <resource id="Panth_ProductAttachments::type_save" title="Save Type" sortOrder="10"/>
                        <resource id="Panth_ProductAttachments::type_delete" title="Delete Type" sortOrder="20"/>
                    </resource>
                    <resource id="Panth_ProductAttachments::unusedfiles" title="Unused Files" sortOrder="25"/>
                    <resource id="Panth_ProductAttachments::analytics" title="Download Analytics" sortOrder="30"/>
                    <resource id="Panth_ProductAttachments::config" title="Configuration" sortOrder="40"/>
                </resource>
            </resource>
        </resources>
    </acl>
</config>
