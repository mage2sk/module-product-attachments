<csp_whitelist xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Csp:etc/csp_whitelist.xsd">
    <policies>
        <policy id="style-src">
            <values>
                <value id="cdn_jsdelivr" type="host">cdn.jsdelivr.net</value>
            </values>
        </policy>
        <policy id="font-src">
            <values>
                <value id="cdn_jsdelivr_fonts" type="host">cdn.jsdelivr.net</value>
            </values>
        </policy>
    </policies>
</csp_whitelist>
